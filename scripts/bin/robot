#!/usr/bin/env bash

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
WS_ROOT=$(dirname "$(dirname "$SCRIPT_DIR")")
CONFIG_DIR="${WS_ROOT}/src/thermocator/config"


service="${1:-}"
domain_id="${2:-38}"
package="${3:-}"

SETUP="source /opt/ros/jazzy/setup.bash && \
       source ${WS_ROOT}/install/setup.bash && \
       export TURTLEBOT3_MODEL=burger && \
       export ROS_DOMAIN_ID=${domain_id}"

if [ -z "$service" ]; then
    echo "Usage: $0 <service> [domain_id] [package]"
    echo ""
    echo "Services:"
    echo "  teleop       — keyboard teleoperation"
    echo "  rviz         — Cartographer SLAM + RViz2"
    echo "  lifecycle    — Lifecycle manager for Nav2 node management"
    echo "  nav          — Nav2 with thermal costmap params"
    echo "  thermal      — ThermalMapBuilder node"
    echo "  broadcaster  — ThermalBroadcaster (sim sensor)"
    echo "  decision     — DecisionNode (frontier exploration)"
    echo "  thermocator  — Full thermocator pipeline"
    echo "  thermulator  — Entire Thermocator + External stack"
    echo "  map_save     — Save current map to config folder"
    echo "  build        — Build workspace (optional: [package])"
    echo ""
    echo "Resolved Paths:"
    echo "  Workspace Dir : ${WS_ROOT}"
    echo "  Config Dir    : ${CONFIG_DIR}"
    echo "domain_id defaults to 38 if not specified"
    exit 1
fi

case "$service" in
    teleop)
        bash -c "${SETUP} && \
                 ros2 run turtlebot3_teleop teleop_keyboard"
        ;;
 
    rviz)
        bash -c "${SETUP} && \
                 ros2 launch turtlebot3_cartographer cartographer.launch.py"
        ;;

    nav)
        bash -c "${SETUP} && \
                 ros2 launch nav2_bringup navigation_launch.py \
                 use_sim_time:=False \
                 autostart:=False \
                 params_file:=${CONFIG_DIR}/nav2_slam_params.yaml"
        ;;

    lifecycle)
        bash -c "${SETUP} && \
                ros2 run nav2_lifecycle_manager lifecycle_manager \
                --ros-args \
                -p use_sim_time:=false \
                -p autostart:=true \
                -p node_names:='[\"controller_server\",\"smoother_server\",\"planner_server\",\"behavior_server\",\"velocity_smoother\",\"collision_monitor\",\"bt_navigator\",\"waypoint_follower\"]'"
        ;;

    thermal)
        bash -c "${SETUP} && \
                 ros2 run thermocator thermocator"
        ;;

    broadcaster)
        bash -c "${SETUP} && \
                 ros2 run thermocator thermal_broadcaster"
        ;;

    decision)
        bash -c "${SETUP} && \
                 ros2 run thermocator decision_node"
        ;;

    thermocator)
        bash -c "${SETUP} && \
                 ros2 launch thermocator thermocator.launch.py \
                 use_sim_time:=false"
        ;;

    thermulator)
        bash -c "${SETUP} && \
                 ros2 launch thermocator thermulator.launch.py \
                 use_sim_time:=false"
        ;;

    map_save)
        bash -c "${SETUP} && \
                 ros2 run nav2_map_server map_saver_cli \
                 -f ~/turtlebot3_ws/src/thermocator/config/my_map"
        ;;

    build)
        if [ -n "$package" ]; then
            echo "Building package: $package"
            bash -c "${SETUP} && \
                     cd ${WS_ROOT} && \
                     colcon build --packages-select ${package} --symlink-install"
        else
            echo "Building all packages ..."
            bash -c "${SETUP} && \
                     cd ${WS_ROOT} && \
                     colcon build --symlink-install"
        fi
        ;;

    *)
        echo "Error: unknown service '$service'"
        echo "Run $0 without arguments to see usage"
        exit 1
        ;;
esac
