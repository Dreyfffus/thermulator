#!/usr/bin/env bash

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
WS_ROOT=$(dirname "$(dirname "$SCRIPT_DIR")")
CONFIG_DIR="${WS_ROOT}/src/thermocator/config"
RVIZ_CONFIG="${CONFIG_DIR}/thermocator.rviz"

service="${1:-}"
robot_ip="${2:-}"
domain_id="${3:-38}"
package="${4:-}"

SETUP="source /opt/ros/jazzy/setup.bash && \
       source ${WS_ROOT}/install/setup.bash && \
       export TURTLEBOT3_MODEL=burger && \
       export ROS_DOMAIN_ID=${domain_id}"

SIM_SETUP="source /opt/ros/jazzy/setup.bash && \
           source ${WS_ROOT}/install/setup.bash && \
           export TURTLEBOT3_MODEL=burger && \
           export ROS_DOMAIN_ID=1"

BRIDGE_SETUP="source /opt/ros/jazzy/setup.bash && \
              source ${WS_ROOT}/install/setup.bash && \
              export TURTLEBOT3_MODEL=burger"

BRIDGE_CONFIG="${CONFIG_DIR}/domain_bridge.yaml"

if [ -z "$service" ]; then
    echo "Usage: $0 <service> [robot_ip] [domain_id] [package]"
    echo ""
    echo "  On robot via SSH (turtlebot3@robot_ip):"
    echo "  bringup      -- TurtleBot3 bringup (requires robot_ip)"
    echo ""
    echo "  Local -> robot stack (Domain domain_id, default 38):"
    echo "  teleop       -- keyboard teleoperation"
    echo "  rviz         -- Cartographer SLAM + RViz2 with thermocator config"
    echo "  nav          -- Nav2 navigation stack"
    echo "  lifecycle    -- Nav2 lifecycle manager"
    echo "  thermal      -- ThermalMapBuilder node"
    echo "  broadcaster  -- ThermalBroadcaster (simulated sensor)"
    echo "  decision     -- DecisionNode (exploration + actioning)"
    echo "  thermocator  -- Full thermocator pipeline (broadcaster + thermal + decision)"
    echo "  thermulator  -- LOCAL stack: Cartographer + Nav2 + thermocator + arbiter"
    echo "  arbiter      -- GoalArbiter only (selects best LOCAL/TWINNED goal)"
    echo "  map_save     -- Save current map to config folder"
    echo ""
    echo "  Local -> digital twin (Domain 1):"
    echo "  sim          -- Twin Gazebo simulation world"
    echo "  twin         -- TWINNED stack: full thermocator (publishes goals) + battery monitor"
    echo "  battery      -- BatteryMonitor only (logs bridged battery every 10s)"
    echo ""
    echo "  Local -> bridge (no domain):"
    echo "  bridge       -- domain_bridge (Domain ${domain_id} <-> Domain 1)"
    echo ""
    echo "  Build:"
    echo "  build        -- Build all packages (optional: [package])"
    echo ""
    echo "  Paths:"
    echo "  Workspace : ${WS_ROOT}"
    echo "  Config    : ${CONFIG_DIR}"
    echo "  RViz2     : ${RVIZ_CONFIG}"
    echo ""
    echo "  robot_ip  : required only for 'bringup'"
    echo "  domain_id : defaults to 38"
    echo ""
    echo "  Recommended launch order (robot + digital twin):"
    echo "    1. bringup <robot_ip>   -- SSH to robot, wait for sensors"
    echo "    2. thermulator          -- LOCAL stack + arbiter (Domain 38)"
    echo "    3. sim                  -- twin Gazebo (Domain 1, new terminal)"
    echo "    4. bridge               -- domain_bridge (new terminal)"
    echo "    5. twin                 -- TWINNED stack + battery (Domain 1, new terminal)"
    exit 1
fi

rviz_args() {
    if [ -f "${RVIZ_CONFIG}" ]; then
        echo "-d ${RVIZ_CONFIG}"
    else
        echo ""
    fi
}

case "$service" in


    bringup)
        if [ -z "$robot_ip" ]; then
            echo "Error: 'bringup' requires robot_ip"
            echo "Usage: $0 bringup <robot_ip> [domain_id]"
            exit 1
        fi
        echo "Starting TurtleBot3 bringup on turtlebot3@${robot_ip} (Domain ${domain_id}) ..."
        ssh turtlebot3@${robot_ip} \
            "source /opt/ros/jazzy/setup.bash && \
             export TURTLEBOT3_MODEL=burger && \
             export ROS_DOMAIN_ID=${domain_id} && \
             ros2 launch turtlebot3_bringup robot.launch.py"
        ;;


    teleop)
        bash -c "${SETUP} && \
                 ros2 run turtlebot3_teleop teleop_keyboard"
        ;;

    rviz)
        bash -c "${SETUP} && \
                 ros2 launch turtlebot3_cartographer cartographer.launch.py \
                 use_rviz:=False &
                 sleep 3
                 ros2 run rviz2 rviz2 $(rviz_args)"
        ;;

    nav)
        bash -c "${SETUP} && \
                 ros2 launch nav2_bringup navigation_launch.py \
                 use_sim_time:=False \
                 autostart:=False \
                 params_file:=${CONFIG_DIR}/nav2_slam_params.yaml"
        ;;

    lifecycle)
        bash -c "${SETUP} && \
                 ros2 launch thermocator lifecycle_manager.launch.py \
                 use_sim_time:=false"
        ;;

    thermal)
        bash -c "${SETUP} && \
                 ros2 run thermocator thermocator"
        ;;

    broadcaster)
        bash -c "${SETUP} && \
                 ros2 run thermocator thermal_broadcaster"
        ;;

    decision)
        bash -c "${SETUP} && \
                 ros2 run thermocator decision_node"
        ;;

    thermocator)
        bash -c "${SETUP} && \
                 ros2 launch thermocator thermocator.launch.py \
                 use_sim_time:=false"
        ;;

    thermulator)
        bash -c "${SETUP} && \
                 ros2 launch thermocator thermulator.launch.py \
                 use_sim_time:=false goal_source:=LOCAL run_arbiter:=true"
        ;;

    arbiter)
        bash -c "${SETUP} && \
                 ros2 run thermocator goal_arbiter"
        ;;

    map_save)
        bash -c "${SETUP} && \
                 ros2 run nav2_map_server map_saver_cli \
                 -f ${CONFIG_DIR}/my_map"
        ;;


    sim)
        bash -c "${SIM_SETUP} && \
                 ros2 launch my_tb3_world delta_thermulator.launch.py \
                 use_sim_time:=true"
        ;;

    twin)
        bash -c "${SIM_SETUP} && \
                 ros2 launch thermocator thermulator.launch.py \
                 use_sim_time:=true goal_source:=TWINNED \
                 run_arbiter:=false run_battery_monitor:=true"
        ;;

    battery)
        bash -c "${SIM_SETUP} && \
                 ros2 run thermocator battery_monitor"
        ;;


    bridge)
        bash -c "source /opt/ros/jazzy/setup.bash && \
             source ${WS_ROOT}/install/setup.bash && \
             ros2 launch thermocator thermic_bridge.launch.py"
        ;;


    build)
        if [ -n "$package" ]; then
            echo "Building package: $package"
            bash -c "${SETUP} && \
                     cd ${WS_ROOT} && \
                     colcon build --packages-select ${package} --symlink-install \
                     --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
        else
            echo "Building all packages ..."
            bash -c "${SETUP} && \
                     cd ${WS_ROOT} && \
                     colcon build --symlink-install \
                     --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
        fi
        ;;

    *)
        echo "Error: unknown service '$service'"
        echo "Run $0 without arguments to see usage"
        exit 1
        ;;
esac

