#!/usr/bin/env bash
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
WS_ROOT=$(dirname "$(dirname "$SCRIPT_DIR")")

attach="$1"
service="${2:-}"
package="${3:-}"

ROBOT_DOMAIN_ID=38
SIM_DOMAIN_ID=1
DOCKER_TTY="-it"

if [ ! -t 0 ]; then
    DOCKER_TTY="-i"
fi

SETUP="source /opt/ros/jazzy/setup.bash && \
       source /opt/turtlebot3_ws/install/setup.bash && \
       source /ws/install/setup.bash && \
       export TURTLEBOT3_MODEL=burger && \
       export ROS_DOMAIN_ID=${ROBOT_DOMAIN_ID}"

DT_SETUP="source /opt/ros/jazzy/setup.bash && \
       source /opt/turtlebot3_ws/install/setup.bash && \
       source /ws/install/setup.bash && \
       export TURTLEBOT3_MODEL=burger && \
       export ROS_DOMAIN_ID=${SIM_DOMAIN_ID}"

BRIDGE_SETUP="source /opt/ros/jazzy/setup.bash && \
              source /opt/turtlebot3_ws/install/setup.bash && \
              source /ws/install/setup.bash && \
              export TURTLEBOT3_MODEL=burger"

RVIZ_CONFIG="/ws/src/thermocator/config/thermocator.rviz"
BRIDGE_CONFIG="/ws/src/thermocator/config/domain_bridge.yaml"

ensure_container() {
    if ! docker ps --format '{{.Names}}' | grep -q "^turtlebot3_container$"; then
        echo "Container not running -- starting it in the background ..."
        docker run --rm -d --name turtlebot3_container --net=host \
            -e DISPLAY=$DISPLAY \
            -v /tmp/.X11-unix:/tmp/.X11-unix \
            -v "${WS_ROOT}:/ws" \
            turtlebot3_ws bash -c \
            "${SETUP} && sleep infinity"
        sleep 1
        echo "Container started."
    else
        echo "Container already running."
    fi
}

if [ -z "$attach" ]; then
    echo "Usage: $0 <start | attach | remote> [service] [package]"
    echo ""
    echo "Commands:"
    echo "  start                -- start a new interactive container session"
    echo "  attach               -- open a shell into the running container"
    echo "  remote <service>     -- run a service inside the container"
    echo ""
    echo "Services (remote):"
    echo "  teleop       -- keyboard teleoperation"
    echo "  rviz         -- Cartographer SLAM + RViz2 with thermocator config"
    echo "  sim          -- Gazebo simulation world (Domain ${SIM_DOMAIN_ID})"
    echo "  nav          -- Nav2 navigation stack"
    echo "  lifecycle    -- Nav2 lifecycle manager"
    echo "  thermal      -- ThermalMapBuilder node"
    echo "  broadcaster  -- ThermalBroadcaster (simulated sensor)"
    echo "  decision     -- DecisionNode (frontier exploration + actioning)"
    echo "  thermocator  -- Full thermocator pipeline (broadcaster + map builder + decision)"
    echo "  thermulator  -- Entire stack (Cartographer + Nav2 + thermocator + RViz2)"
    echo "  build        -- Build workspace (optional: [package])"
    echo ""
    echo "  Digital twin (Domain ${SIM_DOMAIN_ID} <-> Domain ${ROBOT_DOMAIN_ID}):"
    echo "  bridge       -- domain_bridge only"
    echo "  advisory     -- AdvisoryNode only"
    echo "  pose_sync    -- PoseSyncNode only"
    echo "  delta_thermal-- Full DT stack (bridge + advisory + pose_sync)"
    echo "  build_dt     -- Build workspace with digital twin nodes (BUILD_DT=ON)"
    exit 1
fi

case "$attach" in
    start)
        echo "Starting session ..."
        docker run --rm -it --name turtlebot3_container --net=host \
            -e DISPLAY=$DISPLAY \
            -v /tmp/.X11-unix:/tmp/.X11-unix \
            -v "${WS_ROOT}:/ws" \
            turtlebot3_ws bash -c \
            "${SETUP} && exec bash"
        ;;

    attach)
        ensure_container
        echo "Attaching to session ..."
        docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
            "${SETUP} && exec bash"
        ;;

    remote)
        ensure_container
        echo "Executing '$service' ..."
        case "$service" in

            teleop)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 run turtlebot3_teleop teleop_keyboard"
                ;;

            rviz)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 launch turtlebot3_cartographer cartographer.launch.py \
                     use_sim_time:=True"
                ;;

            sim)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 launch my_tb3_world new_world.launch.py"
                ;;

            dt)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${DT_SETUP} && \
                     ros2 launch my_tb3_world delta_thermulator.launch.py"
                ;;

            nav)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 launch nav2_bringup navigation_launch.py \
                     use_sim_time:=True \
                     autostart:=False \
                     params_file:=/ws/src/thermocator/config/nav2_slam_params.yaml"
                ;;

            lifecycle)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 run nav2_lifecycle_manager lifecycle_manager \
                     --ros-args \
                     -p use_sim_time:=true \
                     -p autostart:=true \
                     -p node_names:='[\"controller_server\",\"smoother_server\",\"planner_server\",\"behavior_server\",\"velocity_smoother\",\"collision_monitor\",\"bt_navigator\",\"waypoint_follower\"]'"
                ;;

            thermal)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 run thermocator thermocator \
                     --ros-args -p use_sim_time:=true"
                ;;

            broadcaster)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 run thermocator thermal_broadcaster \
                     --ros-args -p use_sim_time:=true"
                ;;

            decision)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 run thermocator decision_node \
                     --ros-args -p use_sim_time:=true"
                ;;

            thermocator)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 launch thermocator thermocator.launch.py \
                     use_sim_time:=true"
                ;;

            thermulator)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${SETUP} && \
                     ros2 launch thermocator thermulator.launch.py \
                     use_sim_time:=true"
                ;;

            build)
                if [ -n "$package" ]; then
                    echo "Building package: $package"
                    docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                        "${SETUP} && \
                         cd /ws && colcon build \
                         --packages-select ${package} --symlink-install \
                         --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
                else
                    echo "Building all packages ..."
                    docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                        "${SETUP} && \
                         cd /ws && colcon build --symlink-install \
                         --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
                fi
                ;;


            bridge)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${BRIDGE_SETUP} && \
                     ros2 launch thermocator thermic_bridge.launch.py"
                ;;

            advisory)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${DT_SETUP} && \
                     ros2 run thermocator advisory_node"
                ;;

            pose_sync)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${DT_SETUP} && \
                     ros2 run thermocator pose_sync_node"
                ;;

            delta_thermal)
                docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                    "${BRIDGE_SETUP} && \
                     export ROS_DOMAIN_ID=${SIM_DOMAIN_ID}
                     ros2 launch thermocator delta_thermal.launch.py"
                ;;

            build_dt)
                if [ -n "$package" ]; then
                    echo "Building package (with DT nodes): $package"
                    docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                        "${SETUP} && \
                         cd /ws && colcon build \
                         --packages-select ${package} --symlink-install \
                         --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
                                      -DBUILD_DT=ON"
                else
                    echo "Building all packages (with DT nodes) ..."
                    docker exec ${DOCKER_TTY} turtlebot3_container bash -c \
                        "${SETUP} && \
                         cd /ws && colcon build --symlink-install \
                         --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
                                      -DBUILD_DT=ON"
                fi
                ;;

            *)
                echo "Error: unknown service '$service'"
                echo "Run $0 without arguments to see usage"
                exit 1
                ;;
        esac
        ;;

    *)
        echo "Error: first argument must be start | attach | remote"
        echo "Usage: $0 <start | attach | remote> [service] [package]"
        exit 1
        ;;
esac
